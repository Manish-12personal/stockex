# Copy to .env in this folder. Never commit .env or paste secrets in chat/support.

PORT=5001
# Public base URL of this API (must match how the browser reaches the callback)
SERVER_URL=http://localhost:5001
# Where OAuth success/error redirects the browser after Zerodha login
CLIENT_URL=http://localhost:3000

MONGODB_URI=mongodb://127.0.0.1:27017/stockex

# Required for admin + user JWT login. Use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=

# Kite Connect — create an app at https://developers.kite.trade
# In that app, set Redirect URL to EXACTLY (no trailing slash unless your server uses one):
#   {SERVER_URL}/api/zerodha/callback
# Example local: http://localhost:5001/api/zerodha/callback
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# Optional Binance API keys — public REST/WS works without them; headers used when set.
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# Kite WebSocket: ≤3000 instruments per connection — higher caused OOM/502 before a hard cap server-side.
# ZERODHA_MAX_WS_TOKENS=3000
# Set true only if admins need full order-book in market_tick payloads (heavy memory).
# ZERODHA_TICK_DEPTH_STREAM=

# Optional: when NSE is closed and Kite/WS has no NIFTY, jackpot bids can still store a test lock price.
# In development this is on by default; in production set USE_DUMMY_NIFTY_FALLBACK=true to enable.
# USE_DUMMY_NIFTY_FALLBACK=
# DUMMY_NIFTY_LTP=24050.07

# Production only: allow Nifty Jackpot bids outside bidding hours (testing). Ignored when NODE_ENV is not production.
# NIFTY_JACKPOT_ALLOW_TEST_BIDDING=

# After games.niftyJackpot.resultTime (IST), auto-lock clearing LTP when there are pending bids (default on). Set false to require manual admin lock only.
# NIFTY_JACKPOT_AUTO_LOCK=
